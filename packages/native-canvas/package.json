{
  "name": "native-canvas",
  "version": "0.1.0",
  "main": "dist/native-canvas.js",
  "module": "src/index.ts",
  "unpkg": "dist/native-canvas.js",
  "jsdelivr": "dist/native-canvas.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/native-canvas.js --format=iife --global-name=NativeCanvas --minify-whitespace --minify-syntax --target=es2015",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "5.9.3"
  }
}